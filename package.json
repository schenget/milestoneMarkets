{
  "name": "milestone-markets",
  "private": true,
  "version": "0.1.0",
  "description": "Milestone Markets - multi-channel investment insights platform by Milestonecraft Investments",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:admin dev:web",
    "dev:api": "npm --workspace @milestone/api run dev",
    "dev:admin": "npm --workspace @milestone/admin run dev",
    "dev:web": "npm --workspace @milestone/web run dev",
    "build": "npm-run-all build:packages build:api build:admin build:web",
    "build:packages": "npm --workspace @milestone/core-types run build && npm --workspace @milestone/strategy-engine run build && npm --workspace @milestone/feed-engine run build && npm --workspace @milestone/integration-framework run build && npm --workspace @milestone/trading-placeholder run build",
    "build:api": "npm --workspace @milestone/api run build",
    "build:admin": "npm --workspace @milestone/admin run build",
    "build:web": "npm --workspace @milestone/web run build",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
