{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@milestone/core-types": ["packages/core-types/src"],
      "@milestone/strategy-engine": ["packages/strategy-engine/src"],
      "@milestone/feed-engine": ["packages/feed-engine/src"],
      "@milestone/integration-framework": ["packages/integration-framework/src"],
      "@milestone/trading-placeholder": ["packages/trading-placeholder/src"]
    }
  }
}
